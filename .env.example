# =============================================================================
# 西南大学校园人脸识别门禁系统 · 环境变量模板
#
# 用法：复制此文件为 .env 并填写实际值
#   cp .env.example .env
# 系统启动时会自动读取 .env 文件（通过 python-dotenv）。
# =============================================================================

# ── 数据库连接（可选，默认使用本机开发配置）───────────────────────
# 格式：mysql+asyncmy://用户名:密码@主机:端口/数据库名
FACE_DB_URL=mysql+asyncmy://face_user:replace-with-a-random-password@127.0.0.1:3306/face_gate

# ── JWT 密钥（生产环境必须修改为随机字符串）────────────────────────
# 生成随机密钥：python -c "import secrets; print(secrets.token_urlsafe(32))"
FACE_JWT_SECRET=replace-with-a-random-secret

# ── VLM 视觉环境感知 API（可选，不需要可跳过）─────────────────────
# VECTORENGINE_API_KEY=your-api-key-here
# DEEPSEEK_API_KEY=your-api-key-here

# ── 前端跳过可选依赖下载（安装卡住时设置）────────────────────────
# PUPPETEER_SKIP_DOWNLOAD=true
# CYPRESS_INSTALL_BINARY=0
